# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# server-side share-link store (generated at runtime, replaced by sqlite in v2.0)
.solpop-shares/

# audit log (runtime, append-only JSON-lines per day)
.solpop-audit/

# local sqlite database (generated by Drizzle)
solpop.db
solpop.db-journal
solpop.db-wal
solpop.db-shm
